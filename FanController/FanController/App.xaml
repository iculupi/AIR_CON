<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="FanController.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Application.Resources>
        <ResourceDictionary>
            <!-- Colors -->
            <Color x:Key="BackgroundDark">#0F0F1A</Color>
            <Color x:Key="SurfaceDark">#1A1A2E</Color>
            <Color x:Key="CardDark">#16213E</Color>
            <Color x:Key="AccentBlue">#0F3460</Color>
            <Color x:Key="AccentCyan">#00D4FF</Color>
            <Color x:Key="AccentGreen">#00FF88</Color>
            <Color x:Key="AccentRed">#FF4444</Color>
            <Color x:Key="TextPrimary">#FFFFFF</Color>
            <Color x:Key="TextSecondary">#8892A4</Color>

            <!-- Styles -->
            <Style TargetType="Label" x:Key="HeadingLabel">
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
            </Style>

            <Style TargetType="Label" x:Key="SubLabel">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
            </Style>

            <Style TargetType="Button" x:Key="PrimaryButton">
                <Setter Property="BackgroundColor" Value="{StaticResource AccentBlue}"/>
                <Setter Property="TextColor" Value="{StaticResource AccentCyan}"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="20,12"/>
            </Style>

            <Style TargetType="Button" x:Key="DangerButton">
                <Setter Property="BackgroundColor" Value="#3D0000"/>
                <Setter Property="TextColor" Value="{StaticResource AccentRed}"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="20,12"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>

</Application>
